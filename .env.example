NODE_ENV=development
LOG_LEVEL=info
PORT=3000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/hermes

DISCORD_BOT_TOKEN=
DISCORD_BOT_USER_ID=
DISCORD_APPLICATION_ID=
DISCORD_ENABLE_GATEWAY=false
DISCORD_GUILD_ID=
DISCORD_DEDICATED_CHANNEL_ID=
DISCORD_OWNER_USER_IDS=

OPENAI_API_KEY=
LLM_PROVIDER=template
LLM_LOG_FILE=logs/llm-runtime.log
OPENAI_MODEL=gpt-5.6
OPENAI_BASE_URL=https://api.openai.com
CODEX_CLI_COMMAND=codex
CODEX_CLI_MODEL=
CODEX_CLI_PROFILE=
CODEX_CLI_SANDBOX=read-only
CODEX_CLI_WORKDIR=
CODEX_CLI_OSS=false
CODEX_CLI_LOCAL_PROVIDER=
LLM_REQUEST_TIMEOUT_MS=30000
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

MEM0_API_KEY=
MEM0_BASE_URL=https://api.mem0.ai

N8N_API_URL=
N8N_API_KEY=
N8N_WEBHOOK_SECRET=

SCHEDULE_TIMEZONE=Asia/Seoul
SCHEDULE_BRIEFING_DISCORD_CHANNEL_ID=
HERMES_SCHEDULE_BRIEFING_WEBHOOK_URL=http://localhost:3000/webhooks/schedule-briefing

HERMES_NEWS_COLLECTION_URL=http://localhost:3000/news/articles
HERMES_NEWS_BRIEFING_WEBHOOK_URL=
NEWS_PROVIDERS=google-news-top
NEWS_QUERY=
NEWS_GOOGLE_LANGUAGE=ko
NEWS_GOOGLE_COUNTRY=KR
NEWS_MAX_ARTICLES=10
NEWS_SOURCE_URLS=
NEWS_COLLECTION_TIMEOUT_MS=5000
NEWS_BRIEFING_DISCORD_CHANNEL_ID=

GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
