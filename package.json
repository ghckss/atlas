{
  "name": "ai-assistant-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Hermes 기반 개인 및 소규모 팀용 AI Assistant Platform",
  "type": "commonjs",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm build && node --env-file-if-exists=.env dist/src/runtime/main.js",
    "start": "node --env-file-if-exists=.env dist/src/runtime/main.js",
    "db:migrate": "node --env-file-if-exists=.env scripts/run-migrations.mjs",
    "discord:commands:sync": "node --env-file-if-exists=.env scripts/sync-discord-commands.mjs",
    "n8n:sync": "node --env-file-if-exists=.env scripts/sync-n8n-workflows.mjs",
    "logs": "node --env-file-if-exists=.env scripts/tail-llm-log.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm typecheck",
    "test": "pnpm build && node --test dist/tests/*.test.js",
    "validate:workflows": "node scripts/validate-workflows.mjs",
    "validate": "pnpm typecheck && pnpm test && pnpm validate:workflows"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "discord.js": "^14.26.5",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "typescript": "^5.8.2"
  }
}
